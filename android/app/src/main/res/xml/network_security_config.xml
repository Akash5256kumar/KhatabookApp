<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow cleartext (plain HTTP) traffic during development.
        Android domain-config entries do not support CIDR-style LAN ranges,
        so a base-config is the safest local-dev option here.
    -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>